# ── Secrets & local config ───────────────────────────────────────────────────
# Config files may cache an Analytics API key — never commit them.
*.config.json
.env
.env.*
!.env.example

# ── Fetched / generated per-client data ──────────────────────────────────────
# Sample records are pulled from the index on demand and can be large.
clients/**/sample-records.json
sample-records.json
sample_records.json

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
.pnp.*

# ── Logs & temp ────────────────────────────────────────────────────────────────
*.log
logs/
tmp/
*.tmp

# ── OS / editor cruft ───────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini
.idea/
.vscode/
*.swp
*.swo
